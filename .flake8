[flake8]
max-line-length = 100
max-complexity = 15
extend-ignore =
    # line too long (handled by black)
    E501,
    # whitespace before ':' (conflicts with black)
    E203,
    # line break before binary operator (conflicts with black)
    W503,
    # ambiguous variable names (common in math-heavy code: l, I, O)
    E741,
    # function call in default argument (common in pytorch)
    B008,
per-file-ignores =
    __init__.py:F401
    tests/*:B011,S101
exclude =
    .git,
    .venv,
    __pycache__,
    build,
    dist,
    *.egg-info,
    preprocessed,
    preprocessed_registered,
    arxiv,
    unified,
